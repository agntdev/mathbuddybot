[
  {
    "name": "/add with two numbers returns the sum",
    "steps": [
      {
        "send": { "text": "/add 5 3" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Result: 8" } }
        ]
      }
    ]
  },
  {
    "name": "/add with no arguments shows usage hint",
    "steps": [
      {
        "send": { "text": "/add" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Usage: /add <number> <number>\nExample: /add 5 3" } }
        ]
      }
    ]
  },
  {
    "name": "/add with non-numeric arguments shows usage hint",
    "steps": [
      {
        "send": { "text": "/add abc def" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Usage: /add <number> <number>\nExample: /add 5 3" } }
        ]
      }
    ]
  }
]